 10 RING_TRAIN_PATH = Path("train_ringreactions.csv")
 11 RING_TEST_PATH = Path("test_ringreactions.csv")
 12 SCHNEIDER50K_PATH = Path("schneider50k.tsv")
 13 SCHNEIDER_COLUMN = "clean_rxn"
