 18 def load_model_from_checkpoint(checkpoint_path: str | None, model_type: str = "pretrained") -> Model:
 19     """
 20     Load a model from checkpoint or create a pretrained baseline.
 21     
 22     Args:
 23         checkpoint_path: Path to Lightning checkpoint file (.ckpt), or None for pretrained baseline
 24         model_type: Type of model - "pretrained", "baseline", "finetuned", or "trained"
 25     
 26     Returns:
 27         Loaded Model instance
 28     """
 29     if checkpoint_path is None or checkpoint_path == "" or checkpoint_path.lower() == "none":
 30         print(f"Loading pretrained baseline model (no checkpoint provided)")
 31         return Model.pretrained()
 32     
 33     checkpoint_path_obj = Path(checkpoint_path)
 34     if not checkpoint_path_obj.exists():
 35         raise FileNotFoundError(f"Checkpoint not found: {checkpoint_path}")
 36     
 37     print(f"Loading {model_type} model from checkpoint: {checkpoint_path}")
 38     model = Model.load_from_checkpoint(checkpoint_path)
 39     return model
