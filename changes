  8 # Create a more realistic dataset with more examples
  9 data = []
 10 reactions = [
 11     "CCO.CC(=O)O>>CCOC(=O)C.O",
 12     "C.O>>CO",
 13     "CC(C)O.CCO>>CCOCC",
 14     "C1=CC=CC=C1.CCBr>>C1=CC=CC=C1CC",
 15     "CC(C)=CCBr.CC(C)>>CC(C)C(C)C",
 16     "c1ccccc1O.CCBr>>c1ccccc1OCC",
 17     "CC(=O)Cl.c1ccccc1>>CC(=O)c1ccccc1",
 18     "c1ccccc1Cl.c1ccccc1>>c1ccccc1c2ccccc2",
 19     "CC(C)Br.CC(=O)O>>CC(C)OC(=O)C",
 20     "c1ccccc1Br.c1ccccc1>>c1ccccc1c2ccccc2",
 21 ] * 5  # Repeat to get 50 examples
 22 
 23 print(f"Loading {len(reactions)} reactions...")
 24 for smiles_str in reactions:
 25     try:
 26         r = smiles(smiles_str)
 27         r.canonicalize()
 28         data.append(r.pack())
 29     except Exception as e:
 30         print(f"Warning: Could not parse {smiles_str}: {e}")
 31 
 32 print(f"Loaded {len(data)} reactions successfully\n")
 33 
 34 # Load pretrained model for inference demo
 35 model = Model.pretrained()
 36 model.eval()
 37 
 38 # Create dataloader for inference demo
 39 dl_inference = model.prepare_dataloader(data, batch_size=10)
 40 
 41 print("=" * 60)
 42 print("INFERENCE DEMO - Using Pretrained Model")
 43 print("=" * 60)
 44 for i, batch in enumerate(dl_inference):
 45     embeddings = model(batch)
 46     print(
 47         f"Batch {i}: shape={embeddings.shape}, min={embeddings.min():.4f}, max={embeddings.max():.4f}, mean={embeddings.mean():.4f}"
 48     )
 49     if i >= 2:  # Just show first 3 batches
 50         break
 51 
 52 print("\n" + "=" * 60)
 53 print("TRAINING - 50 Epochs on Synthetic Data")
 54 print("=" * 60 + "\n")
 55 
 56 # Setup training callbacks
 57 checkpoint_callback = ModelCheckpoint(
 58     monitor="trn_loss_tot",
 59     dirpath="checkpoints",
 60     filename="{epoch:02d}-{trn_loss_tot:.2f}",
 61     save_weights_only=True,
 62     save_top_k=3,
 63     save_last=True,
 64     verbose=True,
 65 )
 66 
 67 # Use CSVLogger for metrics tracking
 68 logger = CSVLogger("lightning_logs", name="rxnmap_training")
 69 
 70 trainer = Trainer(
 71     accelerator="cpu",
 72     devices=1,
 73     precision="32",
 74     max_epochs=50,
 75     callbacks=[checkpoint_callback],
 76     logger=logger,
 77     log_every_n_steps=1,
 78     enable_progress_bar=True,
 79     num_sanity_val_steps=0,  # Skip validation checks for faster training
 80 )
 81 
 82 # Create a fresh model for training
 83 training_model = Model(masking_rate=0.15)
 84 
 85 print(f"Starting training on {len(data)} reactions with batch size 10...")
 86 print(f"Training steps per epoch: {len(data) // 10}\n")
 87 
 88 trainer.fit(training_model, dl_inference)
 89 
 90 print("\n" + "=" * 60)
 91 print("TRAINING COMPLETE")
 92 print("=" * 60)
 93 print(f"Best model checkpoint: {checkpoint_callback.best_model_path}")
 94 if checkpoint_callback.best_model_score is not None:
 95     print(f"Best loss: {checkpoint_callback.best_model_score:.4f}")
 96 print(f"Total epochs completed: {trainer.current_epoch + 1}")
 97 print(f"\nMetrics logged to: lightning_logs/rxnmap_training/")
 98 print("To view metrics, check: lightning_logs/rxnmap_training/version_*/metrics.csv")
 99 

