 42 def evaluate_checkpoint(
 43         checkpoint_path: str | None,
 44         dataset_name: str = "ringreactions",
 45         split: str = "test",
 46         csv_path: str | None = None,
 47         data_root: str | None = None,
 48         batch_size: int = 16,
 49         seed: int = 42,
 50         model_type: str = "pretrained",
 51 ) -> dict[str, float]:
 52     """
 53     Evaluate a single checkpoint on a dataset.
 54     
 55     Args:
 56         checkpoint_path: Path to checkpoint file or None for pretrained
 57         dataset_name: Dataset name ("ringreactions", "uspto50k")
 58         split: Dataset split ("train", "test", "val")
 59         csv_path: Override CSV path for ringreactions
 60         data_root: Root directory for datasets
 61         batch_size: Batch size for evaluation
 62         seed: Random seed for reproducibility
 63         model_type: Descriptive name for the model type
 64     
 65     Returns:
 66         Dictionary of evaluation metrics
 67     """
 68     seed_everything(seed, workers=True)
 69     
 70     if dataset_name.lower() == "ringreactions":
 71         path = csv_path or f"{split}_ringreactions.csv"
 72         eval_dataset = get_dataset("ringreactions", split=split, csv_path=path, root=data_root)
 73     else:
 74         eval_dataset = get_dataset(dataset_name, split=split, root=data_root)
 75     
 76     print_dataset_stats(eval_dataset)
 77     
 78     if len(eval_dataset.packed) == 0:
 79         raise RuntimeError("No valid reactions available in evaluation dataset.")
 80     
 81     model = load_model_from_checkpoint(checkpoint_path, model_type)
 82     model.eval()
 83     
 84     metrics = evaluate_model(model, eval_dataset, batch_size=batch_size, mask_seed=seed)
 85     print_metrics(f"{model_type}_on_{dataset_name}_{split}", metrics)
 86     
 87     return metrics
 88 
 89 
 90 def main(
 91         dataset: str = "ringreactions",
 92         split: str = "test",
 93         csv_path: str | None = None,
 94         data_root: str | None = None,
 95         baseline_checkpoint: str | None = None,
 96         finetuned_checkpoint: str | None = None,
 97         trained_checkpoint: str | None = None,
 98         batch_size: int = 16,
 99         seed: int = 42,
100         output_json: str = "experiment_results/nora_eval_summary.json",
101 ) -> dict[str, dict[str, float] | str]:
102     """
103     Evaluate multiple model checkpoints on a given dataset and compare results.
104     
105     Args:
106         dataset: Path to evaluation dataset CSV file
107         baseline_checkpoint: Path to baseline model checkpoint (or None for pretrained)
108         finetuned_checkpoint: Path to finetuned model checkpoint (optional)
109         trained_checkpoint: Path to trained-from-scratch model checkpoint (optional)
110         batch_size: Batch size for evaluation
111         seed: Random seed for reproducibility
112     
113     Usage:
114         # Evaluate pretrained baseline only
115         python nora_eval.py --dataset=test.csv
116         
117         # Evaluate baseline and finetuned
118         python nora_eval.py --dataset=test.csv --baseline_checkpoint=ckpt/baseline.ckpt --finetuned_checkpoint=ckpt/finetuned.ckpt
119         
120         # Evaluate all three models
121         python nora_eval.py --dataset=test.csv --baseline_checkpoint=ckpt/baseline.ckpt --finetuned_checkpoint=ckpt/finetuned.ckpt --trained_checkpoint=ckpt/trained.ckpt
122     """
123     results = {}
124     
125     print("=" * 80)
126     print("BASELINE MODEL EVALUATION")
127     print("=" * 80)
128     baseline_metrics = evaluate_checkpoint(
129         baseline_checkpoint,
130         dataset_name=dataset,
131         split=split,
132         csv_path=csv_path,
133         data_root=data_root,
134         batch_size=batch_size,
135         seed=seed,
136         model_type="baseline",
137     )
138     results["baseline"] = baseline_metrics
139     
140     if finetuned_checkpoint:
141         print("\n" + "=" * 80)
142         print("FINETUNED MODEL EVALUATION")
143         print("=" * 80)
144         finetuned_metrics = evaluate_checkpoint(
145             finetuned_checkpoint, dataset, split, csv_path, data_root, batch_size, seed, model_type="finetuned"
146         )
147         results["finetuned"] = finetuned_metrics
148     
149     if trained_checkpoint:
150         print("\n" + "=" * 80)
151         print("TRAINED-FROM-SCRATCH MODEL EVALUATION")
152         print("=" * 80)
153         trained_metrics = evaluate_checkpoint(
154             trained_checkpoint, dataset, split, csv_path, data_root, batch_size, seed, model_type="trained"
155         )
156         results["trained"] = trained_metrics
157     
158     print("\n" + "=" * 80)
159     print("COMPARISON SUMMARY")
160     print("=" * 80)
161     
162     metric_keys = [
163         "mlm_loss_total",
164         "mlm_atom_accuracy",
165         "mlm_neighbor_accuracy",
166         "mapping_atom_accuracy",
167         "mapping_exact_match",
168         "mapping_top1",
169         "mapping_topk",
170     ]
171     
172     for key in metric_keys:
173         print(f"\n{key}:")
174         for model_name, metrics in results.items():
175             if key in metrics:
176                 value = metrics[key]
177                 print(f"  {model_name:15s}: {value:.6f}")
178         
179         if len(results) > 1 and key in results["baseline"]:
180             baseline_value = results["baseline"][key]
181             for model_name, metrics in results.items():
182                 if model_name != "baseline" and key in metrics:
183                     delta = metrics[key] - baseline_value
184                     print(f"  {model_name:15s} delta: {delta:+.6f}")
185 
186     payload = {
187         "dataset": dataset,
188         "split": split,
189         "seed": seed,
190         "batch_size": batch_size,
191         "results": results,
192     }
193     payload["summary_json"] = write_json(output_json, payload)
194     return payload
195 
196 
197 if __name__ == "__main__":
198     fire.Fire(main)
199 

nora_optuna.py --- Python
  1 from __future__ import annotations
  2 
  3 from typing import Literal
  4 
  5 import fire
  6 import optuna
  7 
  8 from datasets import get_dataset, print_dataset_stats
  9 from nora import (
 10     Model,
 11     evaluate_model,
 12     print_metrics,
 13     run_scratch_experiment,
 14     run_finetune_experiment,
 15     write_json,
 16 )
 17 
 18 
 19 def main(
 20         dataset: str = "ringreactions",
 21         train: str | None = None,
 22         test: str | None = None,
 23         data_root: str | None = None,
 24         n_trials: int = 5,
 25         max_epochs: int | None = None,
 26         batch_size: int = 16,
 27         seed: int = 42,
 28         study_name: str = "rxnmap_optuna",
 29         use_aim: bool = True,
 30         mode: Literal["finetune", "scratch"] = "finetune",
 31         use_supervised_loss: bool = False,
 32         mlm_weight: float = 0.1,
 33         output_json: str = "experiment_results/nora_optuna_summary.json",
 34 ) -> dict[str, object]:
 35     """
 36     Hyperparameter tuning with Optuna.
 37     
 38     Args:
 39         dataset: Dataset name ("ringreactions", "uspto50k")
 40         train: Training split name or CSV path for ringreactions
 41         test: Test split name or CSV path for ringreactions
 42         data_root: Root directory for datasets
 43         n_trials: Number of Optuna trials
 44         max_epochs: Max training epochs (default: 10 for finetune, 100 for scratch)
 45         batch_size: Batch size
 46         seed: Random seed
 47         study_name: Optuna study name
 48         use_aim: Enable Aim logging
 49         mode: Training mode ("finetune" or "scratch")
 50         use_supervised_loss: Use supervised mapping loss
 51         mlm_weight: Weight for MLM loss when using supervised loss
 52     
 53     Examples:
 54         # Ring reactions (default)
 55         uv run nora_optuna.py --dataset=ringreactions --mode=finetune
 56         
 57         # USPTO-50k
 58         uv run nora_optuna.py --dataset=uspto50k --data_root=data/
 59         
 60         # Custom CSV files
 61         uv run nora_optuna.py --dataset=ringreactions --train=my_train.csv --test=my_test.csv
 62         
 63         # Supervised mapping loss
 64         uv run nora_optuna.py --dataset=ringreactions --use_supervised_loss=True
 65     """
 66     if dataset.lower() == "ringreactions":
 67         train_path = train or "train_ringreactions.csv"
 68         test_path = test or "test_ringreactions.csv"
 69         train_dataset = get_dataset("ringreactions", split="train", csv_path=train_path, root=data_root)
 70         test_dataset = get_dataset("ringreactions", split="test", csv_path=test_path, root=data_root)
 71     else:
 72         train_split = train or "train"
 73         test_split = test or "test"
 74         train_dataset = get_dataset(dataset, split=train_split, root=data_root)
 75         test_dataset = get_dataset(dataset, split=test_split, root=data_root)
 76 
 77     print_dataset_stats(train_dataset)
 78     print_dataset_stats(test_dataset)
 79 
 80     if len(train_dataset.packed) == 0 or len(test_dataset.packed) == 0:
 81         raise RuntimeError("No valid reactions available after parsing train/test datasets.")
 82 
 83     print(f"\n{'=' * 70}")
 84     print(f"TRAINING MODE: {mode.upper()}")
 85     if use_supervised_loss:
 86         print(f"SUPERVISED LOSS: ENABLED (MLM weight: {mlm_weight})")
 87     else:
 88         print(f"SUPERVISED LOSS: DISABLED (MLM-only)")
 89     print(f"{'=' * 70}\n")
 90 
 91     # Set default epochs based on mode if not specified
 92     epochs = max_epochs if max_epochs is not None else (10 if mode == "finetune" else 100)
 93     print(f"Using max_epochs={epochs} for {mode} mode\n")
 94 
 95     baseline_metrics = evaluate_model(
 96         Model.pretrained(), test_dataset, batch_size=batch_size, mask_seed=seed
 97     )
 98     print_metrics("pretrained_baseline_on_test", baseline_metrics)
 99 
100     def objective(trial: optuna.Trial) -> float:
101         masking_rate = trial.suggest_float("masking_rate", 0.05, 0.35)
102 
103         if mode == "finetune":
104             # Lower learning rates for finetuning
105             learning_rate = trial.suggest_float("learning_rate", 1e-6, 1e-4, log=True)
106 
107             metrics = run_finetune_experiment(
108                 train_dataset,
109                 test_dataset,
110                 batch_size=batch_size,
111                 max_epochs=epochs,
112                 seed=seed + trial.number,
113                 masking_rate=masking_rate,
114                 finetune_learning_rate=learning_rate,
115                 run_name=f"{study_name}_trial_{trial.number}",
116                 use_aim=use_aim,
117                 aim_experiment=study_name,
118                 use_supervised_loss=use_supervised_loss,
119                 mlm_weight=mlm_weight,
120             )
121         else:  # mode == "scratch"
122             # Higher learning rates and tune dropout for scratch training
123             learning_rate = trial.suggest_float("learning_rate", 1e-5, 5e-4, log=True)
124             dropout = trial.suggest_float("dropout", 0.0, 0.3)
125 
126             metrics = run_scratch_experiment(
127                 train_dataset,
128                 test_dataset,
129                 batch_size=batch_size,
130                 max_epochs=epochs,
131                 seed=seed + trial.number,
132                 masking_rate=masking_rate,
133                 learning_rate=learning_rate,
134                 dropout=dropout,
135                 run_name=f"{study_name}_trial_{trial.number}",
136                 use_aim=use_aim,
137                 aim_experiment=study_name,
138                 use_supervised_loss=use_supervised_loss,
139                 mlm_weight=mlm_weight,
140             )
141 
142         trial.set_user_attr("mlm_loss_total", metrics["mlm_loss_total"])
143         trial.set_user_attr("mlm_loss_atom", metrics["mlm_loss_atom"])
144         trial.set_user_attr("mlm_loss_neighbor", metrics["mlm_loss_neighbor"])
145         trial.set_user_attr("mlm_atom_accuracy", metrics["mlm_atom_accuracy"])
146         trial.set_user_attr("mlm_neighbor_accuracy", metrics["mlm_neighbor_accuracy"])
147         trial.set_user_attr("mlm_perplexity", metrics["mlm_perplexity"])
148         trial.set_user_attr("mapping_atom_accuracy", metrics["mapping_atom_accuracy"])
149         trial.set_user_attr("mapping_exact_match", metrics["mapping_exact_match"])
150         trial.set_user_attr("mapping_top1", metrics["mapping_top1"])
151         trial.set_user_attr("mapping_topk", metrics["mapping_topk"])
152         trial.set_user_attr("mapping_assignment_coverage", metrics["mapping_assignment_coverage"])
153         trial.set_user_attr("mapping_mean_similarity", metrics["mapping_mean_similarity"])
154 
155         # Print trial results
156         print(f"\n{'=' * 70}")
157         print(f"TRIAL {trial.number} RESULTS ({mode.upper()})")
158         print(f"{'=' * 70}")
159         print(f"Hyperparameters:")
160         print(f"  masking_rate: {masking_rate:.6f}")
161         print(f"  learning_rate: {learning_rate:.6e}")
162         if mode == "scratch":
163             print(f"  dropout: {dropout:.6f}")
164         print(f"Metrics:")
165         print(f"  mlm_loss_total: {metrics['mlm_loss_total']:.6f}")
166         print(f"  mlm_atom_accuracy: {metrics['mlm_atom_accuracy']:.6f}")
167         print(f"  mlm_neighbor_accuracy: {metrics['mlm_neighbor_accuracy']:.6f}")
168         print(f"  mapping_atom_accuracy: {metrics['mapping_atom_accuracy']:.6f}")
169         print(f"  mapping_exact_match: {metrics['mapping_exact_match']:.6f}")
170         print(f"  mapping_top1: {metrics['mapping_top1']:.6f}")
171         print(f"  mapping_topk: {metrics['mapping_topk']:.6f}")
172         print(f"{'=' * 70}\n")
173 
174         return float(metrics["mapping_atom_accuracy"])
175 
176     study = optuna.create_study(direction="maximize", study_name=study_name)
177     study.optimize(objective, n_trials=n_trials)
178 
179     print("=" * 60)
180     print("OPTUNA BEST TRIAL")
181     print("=" * 60)
182     print(f"best_value(mapping_atom_accuracy): {study.best_value:.6f}")
183     print(f"best_params: {study.best_trial.params}")
184     print(f"best_trial_mlm_loss_total: {study.best_trial.user_attrs.get('mlm_loss_total'):.6f}")
185     print(f"best_trial_mlm_atom_accuracy: {study.best_trial.user_attrs.get('mlm_atom_accuracy'):.6f}")
186     print(f"best_trial_mlm_neighbor_accuracy: {study.best_trial.user_attrs.get('mlm_neighbor_accuracy'):.6f}")
187     print(
188         f"best_trial_mapping_exact_match: {study.best_trial.user_attrs.get('mapping_exact_match'):.6f}"
189     )
190     print(f"best_trial_mapping_topk: {study.best_trial.user_attrs.get('mapping_topk'):.6f}")
191 
192     trials_summary = []
193     for trial in study.trials:
194         trials_summary.append(
195             {
196                 "number": trial.number,
197                 "state": str(trial.state),
198                 "value": trial.value,
199                 "params": trial.params,
200                 "user_attrs": trial.user_attrs,
201             }
202         )
203 
204     payload = {
205         "study_name": study_name,
206         "mode": mode,
207         "use_supervised_loss": use_supervised_loss,
208         "mlm_weight": mlm_weight,
209         "n_trials": n_trials,
210         "max_epochs": epochs,
211         "batch_size": batch_size,
212         "seed": seed,
213         "best_value": study.best_value,
214         "best_params": study.best_trial.params,
215         "best_user_attrs": study.best_trial.user_attrs,
216         "baseline_metrics_test": baseline_metrics,
217         "trials": trials_summary,
218     }
219     payload["summary_json"] = write_json(output_json, payload)
220     return payload
221 
222 
223 if __name__ == "__main__":
224     fire.Fire(main)
225 

run_ring_comparison.py --- Python
  1 from __future__ import annotations
  2 
  3 from pathlib import Path
  4 from typing import Any
  5 
  6 import fire
  7 
  8 from datasets import CombinedReactionDataset, get_dataset, print_dataset_stats
  9 from nora import (
 10     Model,
 11     evaluate_model,
 12     run_finetune_experiment,
 13     run_scratch_experiment,
 14     write_json,
 15 )
 16 
 17 
 18 def _evaluate_splits(
 19         model: Model,
 20         train_dataset: Any,
 21         test_dataset: Any,
 22         batch_size: int,
 23         seed: int,
 24 ) -> dict[str, dict[str, float]]:
 25     return {
 26         "train": evaluate_model(model, train_dataset, batch_size=batch_size, mask_seed=seed),
 27         "test": evaluate_model(model, test_dataset, batch_size=batch_size, mask_seed=seed),
 28     }
 29 
 30 
 31 def _mapping_accuracy_table(
 32         evaluations: dict[str, dict[str, dict[str, float]]]
 33 ) -> dict[str, dict[str, float]]:
 34     return {
 35         split: {
 36             model_name: float(metrics["mapping_atom_accuracy"])
 37             for model_name, split_metrics in evaluations.items()
 38             for current_split, metrics in split_metrics.items()
 39             if current_split == split
 40         }
 41         for split in ("train", "test")
 42     }
 43 
 44 
 45 def main(
 46         batch_size: int = 16,
 47         seed: int = 42,
 48         scratch_epochs: int = 50,
 49         finetune_epochs: int = 10,
 50         masking_rate: float = 0.15,
 51         learning_rate: float = 1e-4,
 52         finetune_learning_rate: float = 1e-5,
 53         dropout: float = 0.1,
 54         mlm_weight: float = 0.1,
 55         accumulate_grad_batches: int = 1,
 56         num_workers: int = 4,
 57         use_combined_train: bool = True,
 58         use_aim: bool = True,
 59         aim_experiment: str = "ring_comparison",
 60         output_dir: str = "experiment_results/ring_comparison",
 61 ) -> dict[str, Any]:
 62     """Run all ring-reactions comparison scenarios.
 63 
 64     Args:
 65         accumulate_grad_batches: Accumulate gradients over N batches (effective batch = batch_size * N).
 66             Use to simulate larger batch sizes without extra VRAM.
 67         num_workers: DataLoader worker processes. Set 0 to disable.
 68         use_combined_train: If True, combine ring train + Schneider50k train as finetuning
 69             source (recommended). If False, use ring train only.
 70     """
 71     ring_train = get_dataset("ringreactions", split="train")
 72     ring_test = get_dataset("ringreactions", split="test")
 73 
 74     print_dataset_stats(ring_train)
 75     print_dataset_stats(ring_test)
 76 
 77     if len(ring_train.packed) == 0 or len(ring_test.packed) == 0:
 78         raise RuntimeError("No valid reactions available after parsing train/test datasets.")
 79 
 80     if use_combined_train:
 81         schneider_train = get_dataset("schneider50k", split="train")
 82         print_dataset_stats(schneider_train)
 83         finetune_train = CombinedReactionDataset(ring_train, schneider_train, name="ring+schneider-train")
 84         print(f"Combined train dataset: {finetune_train}")
 85     else:
 86         finetune_train = ring_train
 87 
 88     finetune_mlm = run_finetune_experiment(
 89         train_dataset=finetune_train,
 90         test_dataset=ring_test,
 91         batch_size=batch_size,
 92         max_epochs=finetune_epochs,
 93         seed=seed,
 94         masking_rate=masking_rate,
 95         finetune_learning_rate=finetune_learning_rate,
 96         run_name="ring_finetune_mlm",
 97         use_aim=use_aim,
 98         aim_experiment=aim_experiment,
 99         use_supervised_loss=False,
100         mlm_weight=mlm_weight,
101         accumulate_grad_batches=accumulate_grad_batches,
102         num_workers=num_workers,
103     )
104     finetune_supervised = run_finetune_experiment(
105         train_dataset=finetune_train,
106         test_dataset=ring_test,
107         batch_size=batch_size,
108         max_epochs=finetune_epochs,
109         seed=seed + 1,
110         masking_rate=masking_rate,
111         finetune_learning_rate=finetune_learning_rate,
112         run_name="ring_finetune_supervised",
113         use_aim=use_aim,
114         aim_experiment=aim_experiment,
115         use_supervised_loss=True,
116         mlm_weight=mlm_weight,
117         accumulate_grad_batches=accumulate_grad_batches,
118         num_workers=num_workers,
119     )
120     scratch_mlm = run_scratch_experiment(
121         train_dataset=ring_train,
122         test_dataset=ring_test,
123         batch_size=batch_size,
124         max_epochs=scratch_epochs,
125         seed=seed + 2,
126         masking_rate=masking_rate,
127         learning_rate=learning_rate,
128         dropout=dropout,
129         run_name="ring_scratch_mlm",
130         use_aim=use_aim,
131         aim_experiment=aim_experiment,
132         use_supervised_loss=False,
133         mlm_weight=mlm_weight,
134         accumulate_grad_batches=accumulate_grad_batches,
135         num_workers=num_workers,
136     )
137     scratch_supervised = run_scratch_experiment(
138         train_dataset=ring_train,
139         test_dataset=ring_test,
140         batch_size=batch_size,
141         max_epochs=scratch_epochs,
142         seed=seed + 3,
143         masking_rate=masking_rate,
144         learning_rate=learning_rate,
145         dropout=dropout,
146         run_name="ring_scratch_supervised",
147         use_aim=use_aim,
148         aim_experiment=aim_experiment,
149         use_supervised_loss=True,
150         mlm_weight=mlm_weight,
151         accumulate_grad_batches=accumulate_grad_batches,
152         num_workers=num_workers,
153     )
154 
155     checkpoints = {
156         "finetune_mlm": str(finetune_mlm.get("last_checkpoint", "")),
157         "finetune_supervised": str(finetune_supervised.get("last_checkpoint", "")),
158         "scratch_mlm": str(scratch_mlm.get("last_checkpoint", "")),
159         "scratch_supervised": str(scratch_supervised.get("last_checkpoint", "")),
160     }
161     missing = [name for name, ckpt in checkpoints.items() if not ckpt or not Path(ckpt).exists()]
162     if missing:
163         raise RuntimeError(f"Missing checkpoint files for: {', '.join(missing)}")
164 
165     models = {
166         "pretrained": Model.pretrained(),
167         "finetune_mlm": Model.load_from_checkpoint(checkpoints["finetune_mlm"]),
168         "finetune_supervised": Model.load_from_checkpoint(checkpoints["finetune_supervised"]),
169         "scratch_mlm": Model.load_from_checkpoint(checkpoints["scratch_mlm"]),
170         "scratch_supervised": Model.load_from_checkpoint(checkpoints["scratch_supervised"]),
171     }
172     for model in models.values():
173         model.eval()
174 
175     evaluations = {
176         name: _evaluate_splits(model, ring_train, ring_test, batch_size=batch_size, seed=seed)
177         for name, model in models.items()
178     }
179     accuracies = _mapping_accuracy_table(evaluations)
180 
181     results = {
182         "dataset": "ringreactions",
183         "use_combined_train": use_combined_train,
184         "batch_size": batch_size,
185         "seed": seed,
186         "scratch_epochs": scratch_epochs,
187         "finetune_epochs": finetune_epochs,
188         "masking_rate": masking_rate,
189         "learning_rate": learning_rate,
190         "finetune_learning_rate": finetune_learning_rate,
191         "dropout": dropout,
192         "mlm_weight": mlm_weight,
193         "use_aim": use_aim,
194         "checkpoints": checkpoints,
195         "evaluations": evaluations,
196         "mapping_atom_accuracy": accuracies,
197     }
198 
199     out_dir = Path(output_dir)
200     out_dir.mkdir(parents=True, exist_ok=True)
201     results["results_json"] = write_json(out_dir / "comparison_results.json", results)
202 
203     lines = []
204     for split in ("train", "test"):
205         for model_name in ("pretrained", "finetune_mlm", "finetune_supervised", "scratch_mlm", "scratch_supervised"):
206             lines.append(f"{split.upper()} {model_name} {accuracies[split][model_name]:.6f}")
207     accuracies_txt = out_dir / "mapping_atom_accuracy.txt"
208     accuracies_txt.write_text("\n".join(lines) + "\n")
209     print(f"Wrote artifacts to: {accuracies_txt}")
210     results["accuracy_table_txt"] = str(accuracies_txt)
211 
212     return results
213 
214 
215 if __name__ == "__main__":
216     fire.Fire(main)
217 

sanity.py --- Python
  1 from chython import smiles
  2 from pytorch_lightning import Trainer
