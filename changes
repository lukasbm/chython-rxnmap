594 def print_metrics(label: str, metrics: dict[str, float | str]):
595     print(f"{label}:")
596     for key in (
597             "mlm_loss_total",
598             "mlm_loss_atom",
599             "mlm_loss_neighbor",
600             "mlm_atom_accuracy",
601             "mlm_neighbor_accuracy",
602             "mlm_perplexity",
603             "mapping_atom_accuracy",
604             "mapping_exact_match",
605             "mapping_top1",
606             "mapping_topk",
607             "mapping_assignment_coverage",
608             "mapping_mean_similarity",
609     ):
610         if key in metrics:
611             print(f"  {key}: {metrics[key]:.6f}")
612     if "last_checkpoint" in metrics:
613         print(f"  last_checkpoint: {metrics['last_checkpoint'] or 'not found'}")
614     if "log_dir" in metrics:
615         print(f"  log_dir: {metrics['log_dir']}")
616 
