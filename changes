204 def build_supervised_training_model(
205     masking_rate: float,
206     learning_rate: float,
207     dropout: float,
208     mlm_weight: float = 0.1,
209 ) -> SupervisedMappingModel:
210     return SupervisedMappingModel(
211         masking_rate=masking_rate,
212         optimizer=partial(AdamW, lr=learning_rate),
213         dropout=dropout,
214         mlm_weight=mlm_weight,
215     )
216 
217 
218 def evaluate_mlm_metrics(
219         model: Model, packed_reactions: list[bytes], batch_size: int, mask_seed: int = 0
220 ) -> dict[str, float]:
221     dataloader = model.prepare_dataloader(packed_reactions, batch_size=batch_size, shuffle=False)
222     model.eval()
223     rng = torch.Generator()
224     rng.manual_seed(mask_seed)
225 
226     atom_total = 0
227     atom_correct = 0
228     neighbor_total = 0
229     neighbor_correct = 0
230     atom_loss_sum = 0.0
231     neighbor_loss_sum = 0.0
232 
233     with torch.no_grad():
234         for a, n, d, r in dataloader:
235             atom_mask = r > 1
236             random_atoms = torch.rand(a.shape, generator=rng, device=a.device)
237             random_neighbors = torch.rand(n.shape, generator=rng, device=n.device)
238             masked_atoms = a.masked_fill((random_atoms < model.masking_rate) & atom_mask, 2)
239             masked_neighbors = n.masked_fill((random_neighbors < model.masking_rate) & atom_mask, 1)
240 
241             embedding = model.encoder((masked_atoms, masked_neighbors, d, r))[atom_mask]
242             atom_logits = model.mlma(embedding)
243             neighbor_logits = model.mlmn(embedding)
244             atom_target = a[atom_mask].long() - 3
245             neighbor_target = n[atom_mask].long() - 2
246 
247             atom_loss = cross_entropy(atom_logits, atom_target)
248             neighbor_loss = cross_entropy(neighbor_logits, neighbor_target)
249 
250             atom_count = atom_target.numel()
251             atom_total += atom_count
252             neighbor_total += atom_count
253             atom_correct += (atom_logits.argmax(dim=-1) == atom_target).sum().item()
254             neighbor_correct += (neighbor_logits.argmax(dim=-1) == neighbor_target).sum().item()
255             atom_loss_sum += atom_loss.item() * atom_count
256             neighbor_loss_sum += neighbor_loss.item() * atom_count
257 
258     atom_loss_value = atom_loss_sum / atom_total
259     neighbor_loss_value = neighbor_loss_sum / neighbor_total
260     total_loss_value = atom_loss_value + neighbor_loss_value
261     return {
262         "mlm_loss_total": total_loss_value,
263         "mlm_loss_atom": atom_loss_value,
264         "mlm_loss_neighbor": neighbor_loss_value,
265         "mlm_atom_accuracy": atom_correct / atom_total,
266         "mlm_neighbor_accuracy": neighbor_correct / neighbor_total,
267         "mlm_perplexity": float(torch.exp(torch.tensor(total_loss_value)).item()),
268     }
269 
270 
271 def _greedy_assignment(similarity: torch.Tensor) -> tuple[list[int], list[float]]:
272     n_product, n_reactant = similarity.shape
273     work = similarity.clone()
274     assigned = [-1] * n_product
275     scores = [float("nan")] * n_product
276 
277     for _ in range(min(n_product, n_reactant)):
278         best_score, flat_index = torch.max(work.reshape(-1), dim=0)
279         if not torch.isfinite(best_score) or best_score.item() <= -1e8:
280             break
281         product_idx = int(flat_index.item() // n_reactant)
282         reactant_idx = int(flat_index.item() % n_reactant)
283         assigned[product_idx] = reactant_idx
284         scores[product_idx] = float(best_score.item())
285         work[product_idx, :] = -1e9
286         work[:, reactant_idx] = -1e9
287     return assigned, scores
288 
289 
290 def evaluate_mapping_metrics(
291     model: Model,
292     dataset: ReactionDatasetBase,
293     top_k: int = 3,
294     batch_size: int = 64,
295 ) -> dict[str, float]:
296     """
297     Evaluate mapping metrics on dataset using PyTorch dataloader for batched inference.
298     
299     Uses standard PyTorch batching for efficient GPU utilization.
300     """
301     model.eval()
302 
303     mapped_reactions = 0
304     exact_matches = 0
305     mappable_atoms = 0
306     correct_atoms = 0
307     top1_hits = 0
308     topk_hits = 0
309     assigned_atoms = 0
310     score_sum = 0.0
311     score_count = 0
312 
313     with torch.no_grad():
314         # Use PyTorch dataloader for efficient batching
315         dataloader = model.prepare_dataloader(dataset.packed, batch_size=batch_size, shuffle=False)
316         
317         # Track which reaction we're on (since dataloader batches are independent of dataset.reactions)
318         reaction_idx = 0
319         
320         for batch in dataloader:
321             atoms, neighbors, distances, roles = batch
322             embeddings = model(batch)
323             batch_size_actual = atoms.shape[0]
324 
325             # Process each reaction in the batch
326             for i in range(batch_size_actual):
327                 if reaction_idx >= len(dataset.reactions):
328                     break
329                 
330                 reaction = dataset.reactions[reaction_idx]
331                 reaction_idx += 1
332                 
333                 atom_tokens = atoms[i]
334                 role_tokens = roles[i]
335                 embedding = embeddings[i]
336 
337                 # Extract reactant and product token indices
338                 reactant_token_idx = torch.where(role_tokens == 2)[0]
339                 product_token_idx = torch.where(role_tokens == 3)[0]
340                 if reactant_token_idx.numel() == 0 or product_token_idx.numel() == 0:
341                     continue
342 
343                 # Get ground truth mappings from reaction
344                 reactant_maps = [n for m in reaction.reactants for n in m]
345                 product_maps = [n for m in reaction.products for n in m]
346                 if len(reactant_maps) != reactant_token_idx.numel() or len(product_maps) != product_token_idx.numel():
347                     continue
348 
349                 # Compute similarity matrix
350                 reactant_map_to_local = {map_num: idx for idx, map_num in enumerate(reactant_maps)}
351                 reactant_embeddings = normalize(embedding[reactant_token_idx], dim=-1)
352                 product_embeddings = normalize(embedding[product_token_idx], dim=-1)
353                 similarity = product_embeddings @ reactant_embeddings.T
354 
355                 # Mask out different atom types
356                 reactant_types = atom_tokens[reactant_token_idx]
357                 product_types = atom_tokens[product_token_idx]
358                 same_atom_type = product_types[:, None] == reactant_types[None, :]
359                 similarity = similarity.masked_fill(~same_atom_type, -1e9)
360 
361                 # Greedy assignment
362                 assigned, assigned_scores = _greedy_assignment(similarity)
363 
364                 # Evaluate metrics for this reaction
365                 has_mappable_atom = False
366                 reaction_is_exact = True
367                 for product_local_idx, product_map_num in enumerate(product_maps):
368                     reactant_local_idx = reactant_map_to_local.get(product_map_num)
369                     if reactant_local_idx is None:
370                         continue
371                     has_mappable_atom = True
372                     mappable_atoms += 1
373 
374                     # Top-k accuracy
375                     ranked_indices = torch.topk(
376                         similarity[product_local_idx],
377                         k=min(top_k, similarity.shape[1]),
378                     ).indices.tolist()
379                     if ranked_indices and ranked_indices[0] == reactant_local_idx:
380                         top1_hits += 1
381                     if reactant_local_idx in ranked_indices:
382                         topk_hits += 1
383 
384                     # Assignment accuracy
385                     predicted_local_idx = assigned[product_local_idx]
386                     if predicted_local_idx != -1:
387                         assigned_atoms += 1
388                         score_sum += assigned_scores[product_local_idx]
389                         score_count += 1
390                     if predicted_local_idx == reactant_local_idx:
391                         correct_atoms += 1
392                     else:
393                         reaction_is_exact = False
394 
395                 if has_mappable_atom:
396                     mapped_reactions += 1
397                     if reaction_is_exact:
398                         exact_matches += 1
399 
400     if mappable_atoms == 0:
401         return {
402             "mapping_atom_accuracy": 0.0,
403             "mapping_exact_match": 0.0,
404             "mapping_top1": 0.0,
405             "mapping_topk": 0.0,
406             "mapping_assignment_coverage": 0.0,
407             "mapping_mean_similarity": 0.0,
408         }
409 
410     return {
411         "mapping_atom_accuracy": correct_atoms / mappable_atoms,
412         "mapping_exact_match": exact_matches / mapped_reactions if mapped_reactions else 0.0,
413         "mapping_top1": top1_hits / mappable_atoms,
414         "mapping_topk": topk_hits / mappable_atoms,
415         "mapping_assignment_coverage": assigned_atoms / mappable_atoms,
416         "mapping_mean_similarity": score_sum / score_count if score_count else 0.0,
417     }
418 
419 
420 def evaluate_model(
421         model: Model, dataset: ReactionDatasetBase, batch_size: int, mask_seed: int = 0
422 ) -> dict[str, float]:
423     mlm_metrics = evaluate_mlm_metrics(model, dataset.packed, batch_size=batch_size, mask_seed=mask_seed)
424     mapping_metrics = evaluate_mapping_metrics(model, dataset, batch_size=batch_size)
425     return {**mlm_metrics, **mapping_metrics}
426 
427 
428 def run_training_experiment(
429         model: Model,
430         train_dataset: ReactionDatasetBase,
431         test_dataset: ReactionDatasetBase,
432         batch_size: int,
433         max_epochs: int,
434         seed: int,
435         run_name: str = "rxnmap_training",
436         use_aim: bool = False,
437         aim_experiment: str | None = None,
438         use_supervised_loss: bool = False,
439         accumulate_grad_batches: int = 1,
440         num_workers: int = 4,
441 ) -> dict[str, float | str]:
442     seed_everything(seed, workers=True)
443     if use_supervised_loss and isinstance(model, SupervisedMappingModel):
444         train_loader = model.prepare_dataloader_supervised(
445             train_dataset.reactions, train_dataset.packed,
446             batch_size=batch_size, shuffle=True, num_workers=num_workers, pin_memory=True, persistent_workers=num_workers > 0,
447         )
448     else:
449         train_loader = model.prepare_dataloader(
450             train_dataset.packed, batch_size=batch_size, shuffle=True, num_workers=num_workers, pin_memory=True, persistent_workers=num_workers > 0,
451         )
452 
453     loggers = [CSVLogger("lightning_logs", name=run_name)]
454     if use_aim:
455         try:
456             from aim.pytorch_lightning import AimLogger
457             aim_logger = AimLogger(
458                 experiment=aim_experiment or run_name,
459                 train_metric_prefix='train/',
460                 val_metric_prefix='val/',
461                 test_metric_prefix='test/',
462             )
463             loggers.append(aim_logger)
464         except Exception as e:
465             print(f"Warning: aim logging unavailable ({type(e).__name__}: {e}), using CSV logger only")
466 
467     progress_bar = TQDMProgressBar(refresh_rate=10)
468 
469     # Use bf16 on Ada/Ampere, fp16 on older, fp32 fallback
470     if torch.cuda.is_available():
471         if torch.cuda.is_bf16_supported():
472             precision = "bf16-mixed"
473         else:
474             precision = "16-mixed"
475     else:
476         precision = "32"
477 
478     accelerator = "cuda" if torch.cuda.is_available() else "cpu"
479 
480     # Ensure CSV logger dir and checkpoint callback so checkpoints are saved
481     csv_logger = loggers[0]
482     ckpt_dir = Path(csv_logger.log_dir) / "checkpoints"
483     ckpt_dir.mkdir(parents=True, exist_ok=True)
484     callbacks = [progress_bar]
485 
486     trainer = Trainer(
487         accelerator=accelerator,
488         devices=1,
489         precision=precision,
490         max_epochs=max_epochs,
491         logger=loggers,
492         log_every_n_steps=10,
493         num_sanity_val_steps=0,
494         enable_progress_bar=True,
495         callbacks=callbacks,
496         accumulate_grad_batches=accumulate_grad_batches,
497     )
498     model.train()
499     trainer.fit(model, train_dataloaders=train_loader)
500     last_checkpoint = ckpt_dir / "last.ckpt"
501     trainer.save_checkpoint(str(last_checkpoint))
502 
503     test_metrics = evaluate_model(model, test_dataset, batch_size=batch_size, mask_seed=seed)
504 
505     return {
506         **test_metrics,
507         "log_dir": csv_logger.log_dir,
508         "last_checkpoint": str(last_checkpoint) if last_checkpoint.exists() else "",
509         "test_metrics_json": write_json(Path(csv_logger.log_dir) / "test_metrics.json", test_metrics),
510     }
511 
512 
513 def run_scratch_experiment(
514         train_dataset: ReactionDatasetBase,
515         test_dataset: ReactionDatasetBase,
516         batch_size: int,
517         max_epochs: int,
518         seed: int,
519         masking_rate: float,
520         learning_rate: float,
521         dropout: float,
522         run_name: str = "rxnmap_training",
523         use_aim: bool = False,
524         aim_experiment: str | None = None,
525         use_supervised_loss: bool = False,
526         mlm_weight: float = 0.1,
527         accumulate_grad_batches: int = 1,
528         num_workers: int = 4,
529 ) -> dict[str, float | str]:
530     if use_supervised_loss:
531         model = build_supervised_training_model(
532             masking_rate=masking_rate,
533             learning_rate=learning_rate,
534             dropout=dropout,
535             mlm_weight=mlm_weight,
536         )
537     else:
538         model = build_training_model(masking_rate, learning_rate, dropout)
539     return run_training_experiment(
540         model,
541         train_dataset=train_dataset,
542         test_dataset=test_dataset,
543         batch_size=batch_size,
544         max_epochs=max_epochs,
545         seed=seed,
546         run_name=run_name,
547         use_aim=use_aim,
548         aim_experiment=aim_experiment,
549         use_supervised_loss=use_supervised_loss,
550         accumulate_grad_batches=accumulate_grad_batches,
551         num_workers=num_workers,
552     )
553 
