 46 class SupervisedMappingModel(Model):
 47     """Model with supervised mapping loss in addition to MLM loss."""
 48     
 49     def __init__(self, *args, mlm_weight: float = 0.1, **kwargs):
 50         super().__init__(*args, **kwargs)
 51         self.mlm_weight = mlm_weight
 52         self._reactions = None
 53     
 54     def set_reactions(self, reactions: list[Any]):
 55         """Store reactions for supervised mapping loss computation."""
 56         self._reactions = reactions
 57     
 58     def prepare_dataloader_supervised(self, reactions: list[Any], packed: list[bytes], **kwargs):
 59         """Prepare dataloader that includes ground truth mappings."""
 60         self._reactions = reactions
 61         ds = ReactionDataset(packed, distance_cutoff=self.encoder.max_distance, unpack=True)
 62         if len(ds) != len(reactions):
 63             raise ValueError(f"Packed reactions ({len(ds)}) and reaction objects ({len(reactions)}) length mismatch.")
 64         paired_items = [(ds[idx], reactions[idx]) for idx in range(len(ds))]
 65 
 66         def collate_with_mappings(batch_items):
 67             from chytorch.utils.data import collate_reactions
 68             reaction_batch = [item[0] for item in batch_items]
 69             atoms, neighbors, distances, roles = collate_reactions(reaction_batch)
 70             
 71             batch_mappings = []
 72             for _, reaction in batch_items:
 73                 reactant_maps = [n for m in reaction.reactants for n in m]
 74                 product_maps = [n for m in reaction.products for n in m]
 75                 batch_mappings.append((reactant_maps, product_maps))
 76             
 77             return atoms, neighbors, distances, roles, batch_mappings
 78         
 79         return DataLoader(paired_items, collate_fn=collate_with_mappings, **kwargs)
 80     
 81     def compute_mapping_loss(self, embeddings: Tensor, atoms: Tensor, roles: Tensor, 
 82                             batch_mappings: list[tuple[list[int], list[int]]]) -> Tensor:
 83         """Compute supervised mapping loss from ground truth."""
 84         total_loss = torch.tensor(0.0, device=embeddings.device)
 85         num_valid = 0
 86         
 87         batch_size = embeddings.shape[0]
 88         for i in range(batch_size):
 89             reactant_maps, product_maps = batch_mappings[i]
 90             if not reactant_maps or not product_maps:
 91                 continue
 92             
 93             role_tokens = roles[i]
 94             embedding = embeddings[i]
 95             atom_tokens = atoms[i]
 96             
 97             # Extract reactant and product indices
 98             reactant_idx = torch.where(role_tokens == 2)[0]
 99             product_idx = torch.where(role_tokens == 3)[0]
100             
101             if len(reactant_maps) != len(reactant_idx) or len(product_maps) != len(product_idx):
102                 continue
103             
104             # Build ground truth mapping matrix
105             # gt_mappings[i, j] = 1 if reactant i maps to product j
106             gt_mappings = torch.zeros(len(reactant_idx), len(product_idx), device=embeddings.device)
107             for r_idx, r_map in enumerate(reactant_maps):
108                 if r_map > 0:  # 0 means unmapped
109                     for p_idx, p_map in enumerate(product_maps):
110                         if p_map == r_map:
111                             # Also check atom types match
112                             r_atom = atom_tokens[reactant_idx[r_idx]]
113                             p_atom = atom_tokens[product_idx[p_idx]]
114                             if r_atom == p_atom:
115                                 gt_mappings[r_idx, p_idx] = 1.0
116             
117             # Skip if no valid mappings
118             if gt_mappings.sum() == 0:
119                 continue
120             
121             # Compute similarity matrix (cosine similarity)
122             r_emb = normalize(embedding[reactant_idx], dim=-1)
123             p_emb = normalize(embedding[product_idx], dim=-1)
124             similarity = torch.mm(r_emb, p_emb.t())  # [n_reactants, n_products]
125             
126             # Compute cross-entropy loss for each reactant atom
127             # We want high similarity for correct mappings
128             for r_idx in range(len(reactant_idx)):
129                 gt_product = gt_mappings[r_idx]
130                 if gt_product.sum() > 0:
131                     # Normalize to get probability distribution
132                     gt_product = gt_product / gt_product.sum()
133                     # Use log_softmax and compute negative log likelihood
134                     log_probs = torch.log_softmax(similarity[r_idx], dim=0)
135                     loss = -(gt_product * log_probs).sum()
136                     total_loss = total_loss + loss
137                     num_valid += 1
138         
139         if num_valid > 0:
140             return total_loss / num_valid
141         return torch.tensor(0.0, device=embeddings.device)
142     
143     def training_step(self, batch, batch_idx):
144         if len(batch) == 5:
145             a, n, d, r, batch_mappings = batch
146         else:
147             a, n, d, r = batch
148             batch_mappings = None
149 
150         m = r > 1  # atoms only
151 
152         ma = a.masked_fill((rand(a.shape, device=a.device) < self.masking_rate) & m, 2)
153         mn = n.masked_fill((rand(n.shape, device=n.device) < self.masking_rate) & m, 1)
154 
155         # Single forward pass — full embeddings used for both MLM and mapping
156         full_embeddings = self.encoder((ma, mn, d, r))
157         x = full_embeddings[m]
158         atoms = self.mlma(x)
159         neighbors = self.mlmn(x)
160 
161         mlm_loss_a = cross_entropy(atoms, a[m].long() - 3)
162         mlm_loss_n = cross_entropy(neighbors, n[m].long() - 2)
163         mlm_loss = mlm_loss_a + mlm_loss_n
164 
165         self.log("trn_loss_mlm_a", mlm_loss_a.item(), sync_dist=True)
166         self.log("trn_loss_mlm_n", mlm_loss_n.item(), sync_dist=True)
167         self.log("trn_loss_mlm", mlm_loss.item(), sync_dist=True)
168 
169         if batch_mappings is not None:
170             mapping_loss = self.compute_mapping_loss(full_embeddings, a, r, batch_mappings)
171             self.log("trn_loss_mapping", mapping_loss.item(), sync_dist=True)
172             total_loss = mapping_loss + self.mlm_weight * mlm_loss
173             self.log("trn_loss_tot", total_loss.item(), sync_dist=True)
174             return total_loss
175         else:
176             self.log("trn_loss_tot", mlm_loss.item(), sync_dist=True)
177             return mlm_loss
178 
179 
180 def build_supervised_finetune_model(
181     masking_rate: float, 
182     finetune_learning_rate: float,
183     mlm_weight: float = 0.1
184 ) -> SupervisedMappingModel:
185     """Build a model with supervised mapping loss."""
186     # Load pretrained weights into supervised model
187     base_model = Model.pretrained()
188     
189     # Create supervised model with same architecture
190     supervised_model = SupervisedMappingModel(
191         masking_rate=masking_rate,
192         mlm_weight=mlm_weight,
193     )
194     
195     # Copy pretrained weights
196     supervised_model.load_state_dict(base_model.state_dict(), strict=False)
197     
198     # Set optimizer
199     supervised_model.optimizer = partial(AdamW, lr=finetune_learning_rate)
200     
201     return supervised_model
202 
