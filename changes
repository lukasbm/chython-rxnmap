163 class CombinedReactionDataset:
164     """Combines multiple ReactionDatasetBase instances into one in-memory dataset.
165 
166     Usage:
167         combined = CombinedReactionDataset(ring_train, schneider_train)
168     """
169 
170     def __init__(self, *datasets: ReactionDatasetBase, name: str | None = None):
171         self.dataset_name = name or "+".join(d.dataset_name for d in datasets)
172         self.split = "combined"
173         self._reactions: list[Any] = [r for d in datasets for r in d.reactions]
174         self._packed: list[bytes] = [p for d in datasets for p in d.packed]
175         self._total: int = sum(d._total for d in datasets)
176         self._failed: int = sum(d._failed for d in datasets)
177 
178     @property
179     def reactions(self) -> list[Any]:
180         return self._reactions
181 
182     @property
183     def packed(self) -> list[bytes]:
184         return self._packed
185 
186     @property
187     def stats(self) -> dict[str, Any]:
188         return {
189             "total": self._total,
190             "valid": len(self._packed),
191             "failed": self._failed,
192             "split": self.split,
193         }
194 
195     def __len__(self) -> int:
196         return len(self._packed)
197 
198     def __repr__(self) -> str:
199         return (
200             f"CombinedReactionDataset('{self.dataset_name}', "
201             f"n={len(self._packed)}, total={self._total}, failed={self._failed})"
202         )
