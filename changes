618 def main(
619         dataset: str = "ringreactions",
620         train_split: str = "train",
621         test_split: str = "test",
622         train_csv: str | None = None,
623         test_csv: str | None = None,
624         data_root: str | None = None,
625         batch_size: int = 16,
626         max_epochs: int = 1,
627         seed: int = 42,
628         masking_rate: float = 0.15,
629         learning_rate: float = 1e-4,
630         finetune_learning_rate: float = 1e-5,
631         dropout: float = 0.1,
632         use_aim: bool = False,
633         aim_experiment: str | None = None,
634         output_json: str = "experiment_results/nora_main_summary.json",
635 ) -> dict[str, Any]:
636     """
637     Train and evaluate reaction mapping models.
638     
639     Args:
640         dataset: Dataset name ("ringreactions", "uspto50k")
641         train_split: Training split name
642         test_split: Test split name
643         train_csv: Override CSV path for ringreactions training
644         test_csv: Override CSV path for ringreactions test
645         data_root: Root directory for datasets
646         batch_size: Batch size
647         max_epochs: Maximum training epochs
648         seed: Random seed
649         masking_rate: MLM masking rate
650         learning_rate: Learning rate for scratch training
651         finetune_learning_rate: Learning rate for finetuning
652         dropout: Dropout rate
653         use_aim: Enable Aim logging
654         aim_experiment: Aim experiment name
655     """
656     if dataset.lower() == "ringreactions":
657         train_path = train_csv or "train_ringreactions.csv"
658         test_path = test_csv or "test_ringreactions.csv"
659         train_dataset = get_dataset("ringreactions", split=train_split, csv_path=train_path, root=data_root)
660         test_dataset = get_dataset("ringreactions", split=test_split, csv_path=test_path, root=data_root)
661     else:
662         train_dataset = get_dataset(dataset, split=train_split, root=data_root)
663         test_dataset = get_dataset(dataset, split=test_split, root=data_root)
664     
665     print_dataset_stats(train_dataset)
666     print_dataset_stats(test_dataset)
667 
668     if len(train_dataset.packed) == 0 or len(test_dataset.packed) == 0:
669         raise RuntimeError("No valid reactions available after parsing train/test datasets.")
670 
671     seed_everything(seed, workers=True)
672     baseline_model = Model.pretrained()
673     baseline_metrics = evaluate_model(
674         baseline_model, test_dataset, batch_size=batch_size, mask_seed=seed
675     )
676     print_metrics("pretrained_baseline_on_test", baseline_metrics)
677 
678     print(
679         f"Training config: epochs={max_epochs}, batch_size={batch_size}, masking_rate={masking_rate}, lr={learning_rate}, finetune_lr={finetune_learning_rate}, dropout={dropout}, use_aim={use_aim}"
680     )
681     scratch_metrics = run_scratch_experiment(
682         train_dataset,
683         test_dataset,
684         batch_size=batch_size,
685         max_epochs=max_epochs,
686         seed=seed,
687         masking_rate=masking_rate,
688         learning_rate=learning_rate,
689         dropout=dropout,
690         use_aim=use_aim,
691         aim_experiment=aim_experiment,
692     )
693     print_metrics("scratch_trained_model_on_test", scratch_metrics)
694 
695     finetuned_metrics = run_finetune_experiment(
696         train_dataset,
697         test_dataset,
698         batch_size=batch_size,
699         max_epochs=max_epochs,
700         seed=seed,
701         masking_rate=masking_rate,
702         finetune_learning_rate=finetune_learning_rate,
703         use_aim=use_aim,
704         aim_experiment=aim_experiment,
705     )
706     print_metrics("finetuned_pretrained_model_on_test", finetuned_metrics)
707 
708     print("=" * 60)
709     print("DELTA (scratch - pretrained)")
710     print("=" * 60)
711     print(
712         f"mlm_loss_total: {scratch_metrics['mlm_loss_total'] - baseline_metrics['mlm_loss_total']:+.6f}"
713     )
714     print(
715         f"mapping_atom_accuracy: {scratch_metrics['mapping_atom_accuracy'] - baseline_metrics['mapping_atom_accuracy']:+.6f}"
716     )
717     print(
718         f"mapping_exact_match: {scratch_metrics['mapping_exact_match'] - baseline_metrics['mapping_exact_match']:+.6f}"
719     )
720     print("=" * 60)
721     print("DELTA (finetuned - pretrained)")
722     print("=" * 60)
723     print(
724         f"mlm_loss_total: {finetuned_metrics['mlm_loss_total'] - baseline_metrics['mlm_loss_total']:+.6f}"
725     )
726     print(
727         f"mapping_atom_accuracy: {finetuned_metrics['mapping_atom_accuracy'] - baseline_metrics['mapping_atom_accuracy']:+.6f}"
728     )
729     print(
730         f"mapping_exact_match: {finetuned_metrics['mapping_exact_match'] - baseline_metrics['mapping_exact_match']:+.6f}"
731     )
732 
733     results = {
734         "dataset": dataset,
735         "train_split": train_split,
736         "test_split": test_split,
737         "seed": seed,
738         "batch_size": batch_size,
739         "max_epochs": max_epochs,
740         "masking_rate": masking_rate,
741         "learning_rate": learning_rate,
742         "finetune_learning_rate": finetune_learning_rate,
743         "dropout": dropout,
744         "baseline_test": baseline_metrics,
745         "scratch_test": scratch_metrics,
746         "finetune_test": finetuned_metrics,
747     }
748     results["summary_json"] = write_json(output_json, results)
749     return results
750 
751 
752 if __name__ == "__main__":
753     fire.Fire(main)
