555 def run_finetune_experiment(
556         train_dataset: ReactionDatasetBase,
557         test_dataset: ReactionDatasetBase,
558         batch_size: int,
559         max_epochs: int,
560         seed: int,
561         masking_rate: float,
562         finetune_learning_rate: float,
563         run_name: str = "rxnmap_finetune",
564         use_aim: bool = False,
565         aim_experiment: str | None = None,
566         use_supervised_loss: bool = False,
567         mlm_weight: float = 0.1,
568         accumulate_grad_batches: int = 1,
569         num_workers: int = 4,
570 ) -> dict[str, float | str]:
571     if use_supervised_loss:
572         model = build_supervised_finetune_model(
573             masking_rate, finetune_learning_rate, mlm_weight=mlm_weight
574         )
575     else:
576         model = build_finetune_model(masking_rate, finetune_learning_rate)
577 
578     return run_training_experiment(
579         model,
580         train_dataset=train_dataset,
581         test_dataset=test_dataset,
582         batch_size=batch_size,
583         max_epochs=max_epochs,
584         seed=seed,
585         run_name=run_name,
586         use_aim=use_aim,
587         aim_experiment=aim_experiment,
588         use_supervised_loss=use_supervised_loss,
589         accumulate_grad_batches=accumulate_grad_batches,
590         num_workers=num_workers,
591     )
