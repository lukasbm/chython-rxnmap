 16 class ReactionDatasetBase(InMemoryDataset):
 17     def __init__(self, dataset_name: str, source: Path, split: str):
 18         self.dataset_name = dataset_name
 19         self.source = source
 20         self.split = split
 21         self._reactions: list[Any] = []
 22         self._packed: list[bytes] = []
 23         self._total = 0
 24         self._failed = 0
 25         super().__init__(root=".")
 26 
 27     @property
 28     def raw_file_names(self) -> list[str]:
 29         return []
 30 
 31     @property
 32     def processed_file_names(self) -> list[str]:
 33         return []
 34 
 35     def download(self):
 36         return
 37 
 38     def process(self):
 39         return
 40 
 41     @property
 42     def reactions(self) -> list[Any]:
 43         return self._reactions
 44 
 45     @property
 46     def packed(self) -> list[bytes]:
 47         return self._packed
 48 
 49     def len(self) -> int:
 50         return len(self._packed)
 51 
 52     def get(self, idx: int) -> bytes:
 53         return self._packed[idx]
 54 
 55     @property
 56     def stats(self) -> dict[str, Any]:
 57         return {
 58             "total": self._total,
 59             "valid": len(self._packed),
 60             "failed": self._failed,
 61             "split": self.split,
 62             "source": str(self.source),
 63         }
 64 
 65     def __repr__(self) -> str:
 66         return (
 67             f"{self.__class__.__name__}('{self.dataset_name}', "
 68             f"split='{self.split}', total={self._total}, valid={len(self._packed)}, failed={self._failed})"
 69         )
 70 
 71 
 72 def _parse_reactions(rows: Iterable[str], source: Path) -> tuple[list[Any], list[bytes], int, int]:
 73     reactions: list[Any] = []
 74     packed: list[bytes] = []
 75     total = 0
 76     failed = 0
 77     warning_count = 0
 78 
 79     for row in rows:
 80         reaction_smiles = row.strip()
 81         if not reaction_smiles:
 82             continue
 83         total += 1
 84         try:
 85             reaction = smiles(reaction_smiles)
 86             reaction.canonicalize()
 87             reactions.append(reaction)
 88             packed.append(reaction.pack())
 89         except Exception as exc:
 90             failed += 1
 91             if warning_count < 10:
 92                 print(f"Warning: failed to parse reaction #{total} from {source}: {exc}")
 93                 warning_count += 1
 94 
 95     return reactions, packed, total, failed
 96 
 97 
 98 class RingReactionsDataset(ReactionDatasetBase):
 99     def __init__(self, split: str = "train", csv_path: str | None = None):
100         if split not in {"train", "test"}:
101             raise ValueError(f"ringreactions split must be 'train' or 'test', got '{split}'")
102         path = Path(csv_path) if csv_path else (RING_TRAIN_PATH if split == "train" else RING_TEST_PATH)
103         if not path.exists():
104             raise FileNotFoundError(f"Ring reactions file not found: {path}")
105         super().__init__(dataset_name=f"ringreactions-{split}", source=path, split=split)
106         with path.open("r", newline="") as f:
107             rows = (row[0] for row in csv.reader(f) if row)
108             self._reactions, self._packed, self._total, self._failed = _parse_reactions(rows, path)
109 
110 
111 class Schneider50kDataset(ReactionDatasetBase):
112     def __init__(self, split: str = "train", tsv_path: str | None = None):
113         if split not in {"train", "val", "test", "all"}:
114             raise ValueError(f"schneider50k split must be one of train/val/test/all, got '{split}'")
115         path = Path(tsv_path) if tsv_path else SCHNEIDER50K_PATH
116         if not path.exists():
117             raise FileNotFoundError(f"Schneider file not found: {path}")
118         super().__init__(dataset_name="schneider50k", source=path, split=split)
119 
120         with path.open("r", newline="") as f:
121             reader = csv.DictReader(f, delimiter="\t")
122             all_rows = [row.get(SCHNEIDER_COLUMN, "").strip() for row in reader]
123 
124         n = len(all_rows)
125         if n == 0:
126             self._reactions, self._packed, self._total, self._failed = [], [], 0, 0
127             return
128 
129         train_end = int(n * 0.8)
130         val_end = int(n * 0.9)
131         if split == "train":
132             rows = all_rows[:train_end]
133         elif split == "val":
134             rows = all_rows[train_end:val_end]
135         elif split == "test":
136             rows = all_rows[val_end:]
137         else:
138             rows = all_rows
139 
140         self._reactions, self._packed, self._total, self._failed = _parse_reactions(rows, path)
141 
142 
143 def get_dataset(
144     name: str,
145     split: str = "train",
146     root: str | Path | None = None,
147     **kwargs,
148 ) -> ReactionDatasetBase:
149     del root  # kept for API compatibility; dataset paths are intentionally fixed/simple
150     name_lower = name.lower()
151     if name_lower == "ringreactions":
152         return RingReactionsDataset(split=split, csv_path=kwargs.get("csv_path"))
153     if name_lower in {"schneider50k", "uspto50k"}:
154         return Schneider50kDataset(split=split, tsv_path=kwargs.get("tsv_path"))
155     raise ValueError("Unknown dataset. Use 'ringreactions' or 'schneider50k'.")
156 
